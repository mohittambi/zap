# PostgreSQL (use a pooled URL on Vercel / serverless, e.g. Neon)
DATABASE_URL=postgresql://user:pass@localhost:5432/zap

JWT_SECRET=change-me-in-production
JWT_EXPIRY=7d

# Optional: set when the browser must call a different API origin than this app.
# Leave unset for same-origin /api (recommended for this monolith).
# NEXT_PUBLIC_API_URL=
