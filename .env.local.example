# PostgreSQL — use a real role name (not the literal "user").
# macOS Homebrew: usually your macOS username (run: whoami). Linux/Docker: often postgres.
# DATABASE_URL=postgresql://YOUR_USERNAME:YOUR_PASSWORD@localhost:5432/zap
DATABASE_URL=postgresql://YOUR_USERNAME@localhost:5432/zap

# --- Supabase (optional hosted Postgres) ---
# Zap uses DATABASE_URL only for server-side pg. In Supabase: Settings → Database → copy Connection string (URI).
# Prefer the pooler URL for Vercel/serverless. See docs/supabase-deployment.md
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
# Optional — only if you add @supabase/supabase-js or Edge functions later (not required for current Zap code):
# Supabase → Settings → API Keys → "Publishable and secret API keys" (new) vs legacy anon/service_role tab.
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...   # Publishable key (browser-safe with RLS)
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_...           # Secret key — server-only; never commit

JWT_SECRET=change-me-in-production
JWT_EXPIRY=7d

# Optional: eautomate sync (sync-eautomate-vendor.mjs, sync-eautomate-vendors-all.mjs, sync-eautomate-vendor-pos.mjs)
# Full vendor directory: npm run sync:vendors:all  (GET /public/api/vendors/all → vendors table)
# EAUTOMATE_BASE_URL=https://web.eautomate.in
# EAUTOMATE_COOKIE=access_token=<jwt>; id_token=<jwt>
#   Copy the full Cookie header value from browser DevTools → Network → any eautomate request → Request Headers → Cookie
# EAUTOMATE_BEARER_TOKEN=   # alternative if the API ever accepts Bearer auth
#
# Optional: programmatic login (POST /public/api/login). Zap builds EAUTOMATE_COOKIE from token + id_token.
# Used when cookie is missing or after HTTP 401 (e.g. access_token expired). Do not commit real passwords.
# EAUTOMATE_LOGIN_USER_ID=your.eautomate.userId
# EAUTOMATE_LOGIN_PASSWORD=your-password
# EAUTOMATE_LOGIN_URL=https://web.eautomate.in/public/api/login   # optional; default is {EAUTOMATE_BASE_URL}/public/api/login
# EAUTOMATE_WRITE_AUTH_TO_ENV_LOCAL=1   # optional; after login, upsert EAUTOMATE_COOKIE + login vars into .env.local (see EAUTOMATE_ENV_FILE)
# EAUTOMATE_ENV_FILE=.env.local         # optional; default is cwd/.env.local
#
# Full PO list into vendor_purchase_orders: npm run sync:vendor-pos:all  (requires cookie or token if API is protected)
#   Rows for vendors not in your DB are skipped by default; sync vendors (sync:vendor) or use --strict-vendors to fail instead.
# Import a saved eautomate JSON envelope (with content[]) from the web dir:
#   npm run sync:vendor-pos -- --file path/to/po-dump.json
# If vendor IDs are not in your DB yet, skip those rows instead of failing FK:
#   npm run sync:vendor-pos -- --file path/to/po-dump.json --skip-missing-vendors
# Or pipe JSON:  cat po-dump.json | npm run sync:vendor-pos -- --stdin
#
# Secondary listings (GET paginated + POST sku_wise_details per row): npm run sync:secondary-listings
# If POST returns HTTP 500 (e.g. remote Laravel log permission), rows are still saved from GET.
# Optional: --search-keyword msgb --count 1000 --delay-ms 50 --post-retries 2 --get-only --max-rows 10
# Listings → Secondary preview: optional deep link for "Create association" (labels) in the browser
# NEXT_PUBLIC_EAUTOMATE_CREATE_LABEL_URL=https://web.eautomate.in
#
# Inbound → SKU Wise View: /api/inbound/lot-listings proxies to eautomate
# GET .../purchase_orders/lot-listings/with-search-keyword (same EAUTOMATE_* as above; cookie on the Next server).
#
# Inbound → All GRNs: npm run sync:grns:all  (POST .../purchase_orders/grn/all/paginated → inbound_grns table)
# Run migrate first (025_inbound_grns.sql). Sync vendors before GRNs; rows with unknown vendor_id are skipped unless --strict-vendors.
#
# Inbound → Pending Audits: npm run sync:grns:pending-audit  (POST .../grn/pending_for_audit/paginated)
# Requires migration 026 (inbound_grn_pending_audit queue). Upserts inbound_grns and replaces the queue with returned grn_ids.
#
# Inbound → Pending Invoice Collection: npm run sync:grns:pending-invoice-collection
# POST .../grn/pending_for_invoice_collection/paginated with filter body { grnId, poNumber, vendorInvoiceNumber, vendorIds, vendorNames }.
# Migration 027 (inbound_grn_pending_invoice_collection queue).
#
# Inbound → Pending Debit & Credit Notes: npm run sync:grns:pending-debit-credit
# POST .../purchase_orders/grn/debit_credit_notes/paginated (same filter body as pending invoice collection).
# GET /vendors/all builds the default vendor allowlist (skip rows not in that list; use --strict-vendors for all rows).
# Migration 033 (inbound_pending_debit_credit_notes). UI: /inbound/pending-debit-credit

# Optional: set when the browser must call a different API origin than this app.
# Leave unset for same-origin /api (recommended for this monolith).
# NEXT_PUBLIC_API_URL=

# Inbound → PO detail (vendor PO hub): caches 6 eautomate GETs per PO in inbound_po_detail_* tables.
# npm run sync:po:details -- --vendor <id> --po <id>   or   npm run sync:po:details:from-db
# Same EAUTOMATE_COOKIE / EAUTOMATE_BEARER_TOKEN as GRN detail. Migration 029.
#
# Inbound → Vendor directory + listings from eautomate (all vendors):
#   1) npm run sync:vendors:all   (fills vendors from GET /vendors/all)
#   2) npm run sync:vendors:detail-all   (GET /listings/sku/names once into eautomate_sku_names_cache;
#        then per vendor GET /vendors/{id} + /vendors/listings/{id} → listings, bins, vendor_sku, etc.)
# Optional flags: --limit N, --vendor-id <id>, --continue-on-error
# Migration 030 (eautomate_sku_names_cache; vendors.vendor_contact_number → TEXT).
#
# GRN detail + documents + logs ingest: npm run sync:grn:details -- --grn <id>  |  npm run sync:grn:details:all
# (8 eautomate GETs per GRN). Migration 031: debit/credit notes + grn_api_raw; 032: inbound_grn_logs.
# Optional bulk flag: --continue-on-error
#
# GRN file download proxy (/api/inbound/grns/[grnId]/files/[fileId]): set path templates eAutomate uses
# (discover from browser Network when downloading a file). Placeholders: {fileId} {grnId} {noteId}
# EAUTOMATE_GRN_INVOICE_FILE_URL_PATH=/public/api/...
# EAUTOMATE_GRN_DCN_FILE_URL_PATH=/public/api/...
